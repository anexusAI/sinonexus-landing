import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  Settings, 
  Users, 
  BarChart3, 
  Lock, 
  ChevronRight, 
  Save, 
  RefreshCw,
  TrendingUp,
  ShieldCheck,
  LogOut,
  Mail,
  Phone,
  Calendar,
  Building2
} from 'lucide-react';
import { API_BASE_URL } from '../config';

interface Lead {
  id: number;
  timestamp: string;
  company_name: string;
  contact_name: string;
  email: string;
  phone: string;
  status: string;
}

interface Config {
  weights: {
    criteriaMatch: number;
    trendApproval: number;
    districtFactor: number;
    nationalityMod: number;
    ageFactor: number;
  };
  thresholds: {
    epSalaryMin: number;
    epSalaryFinance: number;
    sPassSalaryMin: number;
    compassMin: number;
  };
}

export const FounderDashboard: React.FC = () => {
  const [isAuthenticated, setIsAuthenticated] = useState(false);
  const [adminKey, setAdminKey] = useState('');
  const [activeTab, setActiveTab] = useState<'algorithm' | 'leads'>('algorithm');
  const [config, setConfig] = useState<Config | null>(null);
  const [leads, setLeads] = useState<Lead[]>([]);
  const [loading, setLoading] = useState(false);
  const [message, setMessage] = useState<{ type: 'success' | 'error', text: string } | null>(null);

  const handleLogin = (e: React.FormEvent) => {
    e.preventDefault();
    // We'll verify by attempting to fetch config
    fetchConfig(adminKey);
  };

  const fetchConfig = async (key: string) => {
    setLoading(true);
    try {
      const res = await fetch(`${API_BASE_URL}/api/admin/config`, {
        headers: { 'Authorization': `Bearer ${key}` }
      });
      if (res.ok) {
        const data = await res.json();
        setConfig(data);
        setIsAuthenticated(true);
        localStorage.setItem('sinonexus_admin_key', key);
        fetchLeads(key);
      } else {
        setMessage({ type: 'error', text: 'Invalid Admin Key' });
      }
    } catch (err) {
      setMessage({ type: 'error', text: 'Connection error' });
    } finally {
      setLoading(false);
    }
  };

  const fetchLeads = async (key: string) => {
    try {
      const res = await fetch(`${API_BASE_URL}/api/admin/leads`, {
        headers: { 'Authorization': `Bearer ${key}` }
      });
      if (res.ok) {
        const data = await res.json();
        setLeads(data);
      }
    } catch (err) {
      console.error('Failed to fetch leads');
    }
  };

  const handleUpdateConfig = async () => {
    if (!config) return;
    setLoading(true);
    try {
      const res = await fetch(`${API_BASE_URL}/api/admin/config`, {
        method: 'POST',
        headers: { 
          'Authorization': `Bearer ${adminKey}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(config)
      });
      if (res.ok) {
        setMessage({ type: 'success', text: 'Algorithm updated successfully' });
        setTimeout(() => setMessage(null), 3000);
      }
    } catch (err) {
      setMessage({ type: 'error', text: 'Update failed' });
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    const savedKey = localStorage.getItem('sinonexus_admin_key');
    if (savedKey) {
      setAdminKey(savedKey);
      fetchConfig(savedKey);
    }
  }, []);

  if (!isAuthenticated) {
    return (
      <div className="min-h-screen bg-slate-50 flex items-center justify-center p-6">
        <motion.div 
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          className="bg-white p-8 rounded-[2.5rem] shadow-xl w-full max-w-md border border-slate-100"
        >
          <div className="w-16 h-16 bg-brand-teal/10 rounded-2xl flex items-center justify-center mb-6 mx-auto">
            <ShieldCheck className="text-brand-teal" size={32} />
          </div>
          <h1 className="text-2xl font-black text-center text-slate-900 mb-2">Founder Access</h1>
          <p className="text-slate-500 text-center mb-8">Enter your secure key to manage SinoNexus</p>
          
          <form onSubmit={handleLogin} className="space-y-4">
            <div className="relative">
              <Lock className="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400" size={20} />
              <input 
                type="password"
                value={adminKey}
                onChange={(e) => setAdminKey(e.target.value)}
                placeholder="Admin Secret Key"
                className="w-full bg-slate-50 border border-slate-200 rounded-2xl pl-12 pr-4 py-4 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 transition-all"
              />
            </div>
            <button 
              disabled={loading}
              className="w-full bg-brand-teal text-white py-4 rounded-2xl font-bold hover:bg-brand-teal/90 transition-all flex items-center justify-center gap-2"
            >
              {loading ? <RefreshCw className="animate-spin" size={20} /> : 'Unlock Dashboard'}
            </button>
            {message && (
              <p className={`text-center text-sm font-medium ${message.type === 'error' ? 'text-red-500' : 'text-emerald-500'}`}>
                {message.text}
              </p>
            )}
          </form>
        </motion.div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-slate-50">
      {/* Header */}
      <header className="bg-white border-b border-slate-200 sticky top-0 z-30">
        <div className="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 bg-brand-teal rounded-xl flex items-center justify-center text-white font-black">SN</div>
            <h1 className="font-black text-xl tracking-tight text-slate-900">Founder Dashboard</h1>
          </div>
          <div className="flex items-center gap-4">
            <button 
              onClick={() => {
                localStorage.removeItem('sinonexus_admin_key');
                window.location.reload();
              }}
              className="p-2 text-slate-400 hover:text-red-500 transition-colors"
            >
              <LogOut size={20} />
            </button>
          </div>
        </div>
      </header>

      <main className="max-w-7xl mx-auto px-6 py-10">
        <div className="grid grid-cols-1 lg:grid-cols-4 gap-8">
          {/* Sidebar Nav */}
          <div className="lg:col-span-1 space-y-2">
            <button 
              onClick={() => setActiveTab('algorithm')}
              className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl font-bold transition-all ${activeTab === 'algorithm' ? 'bg-brand-teal text-white shadow-lg shadow-brand-teal/20' : 'text-slate-500 hover:bg-white'}`}
            >
              <Settings size={20} />
              Algorithm Control
            </button>
            <button 
              onClick={() => setActiveTab('leads')}
              className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl font-bold transition-all ${activeTab === 'leads' ? 'bg-brand-teal text-white shadow-lg shadow-brand-teal/20' : 'text-slate-500 hover:bg-white'}`}
            >
              <Users size={20} />
              Corporate Leads
              {leads.length > 0 && (
                <span className="ml-auto bg-white/20 px-2 py-0.5 rounded-full text-xs">{leads.length}</span>
              )}
            </button>
          </div>

          {/* Content Area */}
          <div className="lg:col-span-3">
            <AnimatePresence mode="wait">
              {activeTab === 'algorithm' && config && (
                <motion.div 
                  key="algo"
                  initial={{ opacity: 0, x: 20 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -20 }}
                  className="space-y-8"
                >
                  {/* Weights Section */}
                  <div className="bg-white p-8 rounded-[2rem] shadow-sm border border-slate-100">
                    <div className="flex items-center justify-between mb-8">
                      <div>
                        <h2 className="text-xl font-black text-slate-900">Algorithm Weights</h2>
                        <p className="text-slate-500 text-sm">Control how different factors influence the probability score</p>
                      </div>
                      <div className="w-12 h-12 bg-brand-orange/10 rounded-xl flex items-center justify-center text-brand-orange">
                        <TrendingUp size={24} />
                      </div>
                    </div>

                    <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                      {Object.entries(config.weights).map(([key, value]) => (
                        <div key={key} className="space-y-2">
                          <label className="text-xs font-bold uppercase tracking-wider text-slate-400">{key.replace(/([A-Z])/g, ' $1')}</label>
                          <div className="flex items-center gap-4">
                            <input 
                              type="range" 
                              min="0" 
                              max="100" 
                              value={value}
                              onChange={(e) => setConfig({
                                ...config,
                                weights: { ...config.weights, [key]: parseInt(e.target.value) }
                              })}
                              className="flex-1 accent-brand-teal"
                            />
                            <span className="w-12 text-right font-mono font-bold text-brand-teal">{value}%</span>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>

                  {/* Thresholds Section */}
                  <div className="bg-white p-8 rounded-[2rem] shadow-sm border border-slate-100">
                    <div className="flex items-center justify-between mb-8">
                      <div>
                        <h2 className="text-xl font-black text-slate-900">Salary Thresholds</h2>
                        <p className="text-slate-500 text-sm">Set the minimum requirements for different pass types</p>
                      </div>
                      <div className="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center text-blue-500">
                        <BarChart3 size={24} />
                      </div>
                    </div>

                    <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                      {Object.entries(config.thresholds).map(([key, value]) => (
                        <div key={key} className="space-y-2">
                          <label className="text-xs font-bold uppercase tracking-wider text-slate-400">{key.replace(/([A-Z])/g, ' $1')}</label>
                          <div className="relative">
                            <span className="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold">$</span>
                            <input 
                              type="number" 
                              value={value}
                              onChange={(e) => setConfig({
                                ...config,
                                thresholds: { ...config.thresholds, [key]: parseInt(e.target.value) }
                              })}
                              className="w-full bg-slate-50 border border-slate-200 rounded-xl pl-8 pr-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-teal/20 font-bold text-slate-700"
                            />
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>

                  {/* Save Button */}
                  <div className="flex justify-end">
                    <button 
                      onClick={handleUpdateConfig}
                      disabled={loading}
                      className="bg-brand-teal text-white px-8 py-4 rounded-2xl font-bold shadow-lg shadow-brand-teal/20 hover:bg-brand-teal/90 transition-all flex items-center gap-2"
                    >
                      {loading ? <RefreshCw className="animate-spin" size={20} /> : <Save size={20} />}
                      Save Changes
                    </button>
                  </div>
                </motion.div>
              )}

              {activeTab === 'leads' && (
                <motion.div 
                  key="leads"
                  initial={{ opacity: 0, x: 20 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -20 }}
                  className="space-y-4"
                >
                  <div className="flex items-center justify-between mb-4">
                    <h2 className="text-2xl font-black text-slate-900">Recent Corporate Leads</h2>
                    <button 
                      onClick={() => fetchLeads(adminKey)}
                      className="p-2 text-slate-400 hover:text-brand-teal transition-colors"
                    >
                      <RefreshCw size={20} />
                    </button>
                  </div>

                  {leads.length === 0 ? (
                    <div className="bg-white p-20 rounded-[2rem] text-center border border-dashed border-slate-200">
                      <Users className="mx-auto text-slate-200 mb-4" size={48} />
                      <p className="text-slate-400 font-medium">No leads captured yet</p>
                    </div>
                  ) : (
                    <div className="space-y-4">
                      {leads.map((lead) => (
                        <motion.div 
                          key={lead.id}
                          layout
                          className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:border-brand-teal/30 transition-all group"
                        >
                          <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
                            <div className="flex items-start gap-4">
                              <div className="w-12 h-12 bg-slate-50 rounded-xl flex items-center justify-center text-slate-400 group-hover:bg-brand-teal/10 group-hover:text-brand-teal transition-colors">
                                <Building2 size={24} />
                              </div>
                              <div>
                                <h3 className="font-bold text-slate-900 text-lg">{lead.company_name}</h3>
                                <p className="text-slate-500 text-sm flex items-center gap-1">
                                  <Users size={14} />
                                  {lead.contact_name}
                                </p>
                              </div>
                            </div>
                            
                            <div className="flex flex-wrap gap-3">
                              <a href={`mailto:${lead.email}`} className="flex items-center gap-2 px-3 py-2 bg-slate-50 rounded-lg text-sm font-medium text-slate-600 hover:bg-brand-teal/10 hover:text-brand-teal transition-all">
                                <Mail size={16} />
                                Email
                              </a>
                              <a href={`tel:${lead.phone}`} className="flex items-center gap-2 px-3 py-2 bg-slate-50 rounded-lg text-sm font-medium text-slate-600 hover:bg-brand-teal/10 hover:text-brand-teal transition-all">
                                <Phone size={16} />
                                Call
                              </a>
                              <div className="flex items-center gap-2 px-3 py-2 bg-slate-50 rounded-lg text-sm font-medium text-slate-400">
                                <Calendar size={16} />
                                {new Date(lead.timestamp).toLocaleDateString()}
                              </div>
                            </div>
                          </div>
                        </motion.div>
                      ))}
                    </div>
                  )}
                </motion.div>
              )}
            </AnimatePresence>
          </div>
        </div>
      </main>

      {/* Message Toast */}
      <AnimatePresence>
        {message && (
          <motion.div 
            initial={{ opacity: 0, y: 50 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: 50 }}
            className={`fixed bottom-8 left-1/2 -translate-x-1/2 px-6 py-3 rounded-full shadow-lg text-white font-bold z-50 ${message.type === 'success' ? 'bg-emerald-500' : 'bg-red-500'}`}
          >
            {message.text}
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
};
